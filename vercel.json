{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/erp run build && pnpm --filter @workspace/api-server run build:vercel",
  "outputDirectory": "artifacts/erp/dist/public",
  "functions": {
    "artifacts/api-server/api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/artifacts/api-server/api/index.js" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
